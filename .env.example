# Ergo node (required — must have wallet unlocked)
ERGO_NODE_URL=http://localhost:9053
API_KEY=your_node_api_key

# Wallet mnemonic (required for fee box address derivation)
ERGO_WALLET_MNEMONIC=your fifteen word mnemonic phrase goes here

# Optional fallback node
# ERGO_FALLBACK_NODE_URL=http://some-public-node:9053

# Optional explorer override
# ERGO_EXPLORER_URL=https://api.ergoplatform.com/api/v1

# Optional Telegram notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=-1001234567890
